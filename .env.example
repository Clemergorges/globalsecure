# ==========================================
# EXEMPLO DE VARIÁVEIS DE AMBIENTE (DEV)
# ==========================================

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5433/globalsecuresend?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5433/globalsecuresend?schema=public"
NODE_ENV="production"

# --- AUTH & SECURITY ---
JWT_SECRET="CHANGE_ME_MIN_32_CHARS"
OTP_PEPPER="CHANGE_ME_MIN_16_CHARS"
SENSITIVE_OTP_PEPPER="CHANGE_ME_MIN_16_CHARS"
SESSION_STRICT_UA="false"

# --- SUPABASE (private buckets / server-side) ---
SUPABASE_URL="https://gvttvtlyxzohqyyrhunu.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="CHANGE_ME"

# --- FX CONFIG ---
FX_PAIRS="USD:EUR,EUR:USD,USD:GBP,USD:BRL"
FX_SPREAD_BPS="75"
FX_MAX_AGE_SECONDS="900"
BASE_CURRENCY="USD"

# --- FEES (Transfers) ---
# Fee model for /api/transfers/create:
# - EXPLICIT: user pays amountSource + fee; recipient receives full amountSource (after FX).
# - NET: user pays amountSource; fee is deducted from amountSource before FX.
FEE_MODEL_TRANSFERS_CREATE="EXPLICIT"

# --- YIELD (Fase 3) ---
YIELD_SPENDING_ENABLED="false"
YIELD_LTV_MAX_BPS="3500"
YIELD_COLLATERAL_VALUE_USD_STUB="0"
YIELD_TERMS_VERSION="1"
YIELD_PER_USER_LIMIT_USD="0"
AML_SANCTIONED_COUNTRIES="IR,KP,SY,RU"
AML_SINGLE_TX_MAX_USD="250"
AML_DAILY_MAX_USD="500"

# --- CRON ---
CRON_SECRET="CHANGE_ME"

# --- SETTLEMENT ENGINE ---
# Enables the settlement sweep for PENDING transfers (via /api/cron/schedule-settlement + queue worker).
SETTLEMENT_ENGINE_ENABLED="true"
# Timeout for auto-refund of PENDING transfers (hours).
SETTLEMENT_TIMEOUT_HOURS="24"
# Batch size per sweep execution.
SETTLEMENT_BATCH_SIZE="50"
# Minimum interval between scheduled settlement jobs (minutes).
SETTLEMENT_JOB_MIN_INTERVAL_MINUTES="2"
# If true, runs sweep without mutating DB/ledger (for safe validation).
SETTLEMENT_DRY_RUN="false"

# --- TREASURY RECONCILIATION ---
# Max age (minutes) for external snapshots to be considered in reconciliation.
TREASURY_SNAPSHOT_MAX_AGE_MIN="180"
# Divergence thresholds (percentage) for audit logging.
TREASURY_DIVERGENCE_WARN_PCT="1"
TREASURY_DIVERGENCE_CRIT_PCT="2"
# Minimum interval between reconciliation jobs scheduled by /api/cron/schedule-finance (minutes).
TREASURY_RECONCILE_MIN_INTERVAL_MINUTES="60"
# Emits audit logs for each run when true.
TREASURY_RECONCILE_EMIT_AUDIT="true"

# --- APP URL (redirects / links) ---
# Used for return_url in Stripe Identity and other absolute links.
NEXT_PUBLIC_APP_URL="https://globalsecuresend.com"

# --- STRIPE (KYC Identity / Payments) ---
# Required to start Stripe Identity verification sessions.
STRIPE_SECRET_KEY="sk_test_CHANGE_ME"

# --- Vercel Blob (KYC manual upload via /api/kyc/submit) ---
# Required by @vercel/blob put(...). Do NOT commit real tokens.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_CHANGE_ME"

# --- SMTP (email verification + sensitive action OTP) ---
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="no-reply@example.com"

# --- PARTNER CIRCUIT BREAKER (Enterprise) ---
# Protects integrations (Stripe, Polygon, Ether.fi) from repeated failures.
PARTNER_BREAKER_ENABLED="true"
PARTNER_BREAKER_WINDOW_SECONDS="600"
PARTNER_BREAKER_ERROR_RATE_WARN="0.2"
PARTNER_BREAKER_ERROR_RATE_OPEN="0.5"

# --- YIELD PROTECTIONS (Enterprise) ---
YIELD_MAX_EXPOSURE_USD="100000"
YIELD_RECONCILE_MIN_INTERVAL_MINUTES="60"
YIELD_RECONCILE_MAX_POSITIONS="50"

# --- JURISDICTION (Enterprise) ---
# Comma-separated ISO-3166 alpha-2 codes to block at the risk-gate layer.
JURISDICTION_BLOCK_COUNTRIES=""
